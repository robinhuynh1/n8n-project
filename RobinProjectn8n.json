    },
    {
      "parameters": {
        "jsCode": "const xml = items[0].json.data;\n\n// Extract items between <item> tags\nconst itemMatches = [...xml.matchAll(/<item>([\\s\\S]*?)<\\/item>/g)].slice(0, 5);\n\nconst articles = itemMatches.map(match => {\n  const block = match[1];\n  \n  const titleMatch = block.match(/<title>([\\s\\S]*?)<\\/title>/);\n  const linkMatch = block.match(/<link>([\\s\\S]*?)<\\/link>/);\n  const descMatch = block.match(/<description>([\\s\\S]*?)<\\/description>/);\n  \n  const title = titleMatch ? titleMatch[1].replace(/<!\\[CDATA\\[|\\]\\]>/g, '').trim() : 'No title';\n  const link = linkMatch ? linkMatch[1].trim() : '';\n  const desc = descMatch ? descMatch[1].replace(/<!\\[CDATA\\[|\\]\\]>/g, '').trim().substring(0, 300) : '';\n\n  return { json: { title, link, desc } };\n});\n\nreturn articles;"
      },
